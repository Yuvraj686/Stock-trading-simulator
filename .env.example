# =============================================================
# Stock Trading Simulator — .env Template
# =============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in all <placeholder> values below
# 3. NEVER commit the real .env — it is in .gitignore
#
# This single .env is the source of truth for the entire project.
# Vite reads VITE_* vars into the frontend bundle.
# FastAPI reads the rest via pydantic-settings (VITE_* are ignored).
# =============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these at: https://app.supabase.com → your-project → Settings → API

SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── API URL ───────────────────────────────────────────────────────────────────
# Dev:  http://localhost:8000
# Prod: https://your-backend-domain.com
VITE_API_BASE_URL=http://localhost:8000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-32-byte-hex-secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── External APIs ─────────────────────────────────────────────────────────────
# Alpha Vantage free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=<your-alpha-vantage-key>

# ── App ───────────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development